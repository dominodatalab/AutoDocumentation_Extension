# Auto Model Documentation - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# Provider: anthropic or openai
# LLM_PROVIDER=anthropic

# Model name override (optional - uses provider default if not set)
# Anthropic default: claude-haiku-4-5
# OpenAI default: gpt-5.4-mini
# LLM_MODEL=claude-haiku-4-5

# API Keys (REQUIRED)
# You can use either the prefixed or non-prefixed versions
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here

# =============================================================================
# Path Configuration
# =============================================================================

# Root directory of codebase to analyze
# Default: /mnt/code (Domino) or current directory
# CODE_ROOT=/path/to/your/codebase

# Output directory for generated documents
# Default: /mnt/data/{DOMINO_PROJECT_NAME} (Domino) or ./output
# OUTPUT_DIR=/path/to/output

# =============================================================================
# Scanning Configuration
# =============================================================================

# Maximum number of files to scan (1-200)
# MAX_FILES=50

# Maximum file size in characters (1000-200000)
# MAX_FILE_SIZE=50000

# =============================================================================
# Generation Configuration
# =============================================================================

# Number of parallel content generation workers (1-10)
# PARALLEL_WORKERS=4

# =============================================================================
# MLflow Configuration
# =============================================================================

# MLflow tracking URI (optional)
# Examples:
#   - Local: file:///path/to/mlruns
#   - Remote: http://localhost:5000
#   - Databricks: databricks
# MLFLOW_TRACKING_URI=

# MLflow experiment name to query (optional)
# MLFLOW_EXPERIMENT_NAME=

# =============================================================================
# Cache Configuration
# =============================================================================

# Enable LLM response caching (true/false)
# CACHE_ENABLED=true

# Directory for cache files
# CACHE_DIR=.autodoc_cache

# =============================================================================
# Alternative: Use AUTODOC_ prefix for all variables
# =============================================================================
# You can also prefix any variable with AUTODOC_ for namespace isolation:
# AUTODOC_ANTHROPIC_API_KEY=your-key
# AUTODOC_LLM_PROVIDER=anthropic
# AUTODOC_MAX_FILES=100
# etc.
