%%{init: {'theme': 'base', 'flowchart': {'wrappingWidth': 500}, 'themeVariables': { 'primaryColor': '#fff', 'secondaryColor': '#fff', 'tertiaryColor': '#fff', 'primaryTextColor': '#374151', 'lineColor': '#9CA3AF', 'primaryBorderColor': '#E5E7EB'}}}%%
flowchart TB
    %% ==================== TITLE ====================
    TITLE@{ shape: text, label: "<b><u>Auto Model Documentation System</u></b>"}
    TITLE ~~~ SPEC
    TITLE ~~~ CODE
    TITLE ~~~ MLFLOW
    TITLE ~~~ CONFIG

    %% ==================== INPUT LAYER ====================
    subgraph INPUTS[" "]
        direction TB
        INPUTS_LABEL["INPUTS"]

        subgraph SPEC[" "]
            SPEC_LABEL["Document Specification"]
            YAML["doc_spec.yaml<br/>─────────────<br/>• title: Document name<br/>• authors: Team info<br/>• sections: List of sections<br/>• hints: LLM guidance"]
        end

        subgraph CODE[" "]
            CODE_LABEL["Python Codebase"]
            PY["*.py files<br/>─────────────<br/>• Training scripts<br/>• Model definitions<br/>• Feature engineering<br/>• Pipeline code"]
        end

        subgraph MLFLOW[" "]
            MLFLOW_LABEL["MLflow Registry"]
            ML["Experiment Data<br/>─────────────<br/>• Registered models<br/>• Metrics & params<br/>• Artifacts<br/>• Run history"]
        end

        subgraph CONFIG[" "]
            CONFIG_LABEL["Configuration"]
            ENV[".env / Environment<br/>─────────────<br/>• API keys (Anthropic/OpenAI)<br/>• MLflow tracking URI<br/>• Worker count<br/>• File limits"]
        end
    end

    %% ==================== ENTRY POINTS ====================
    subgraph ENTRY[" "]
        direction LR
        ENTRY_LABEL["ENTRY POINTS"]
        CLI["CLI (main.py)<br/>─────────────<br/>python main.py --spec doc_spec.yaml<br/>--provider anthropic --notebook"]
        WEB["Web UI (web_app.py)<br/>─────────────<br/>FastHTML @ localhost:8888<br/>Form-based interface<br/>Real-time progress"]
    end

    %% ==================== PHASE 1: SCANNING ====================
    subgraph PHASE1[" "]
        direction TB
        PHASE1_LABEL["PHASE 1: SCAN - Parallel Execution"]

        subgraph CODESCAN[" "]
            CODESCAN_LABEL["Code Scanner"]
            CS1["1. Discover Files<br/>Find *.py (exclude tests/venv)"]
            CS2["2. Prioritize<br/>Rank by ML keywords:<br/>train, model, feature, pipeline"]
            CS3["3. Sanitize<br/>Remove secrets/keys<br/>before LLM processing"]
            CS4["4. LLM Analysis<br/>Claude/GPT extracts:<br/>model classes, features,<br/>target, transformations"]
            CS1 --> CS2 --> CS3 --> CS4
        end

        subgraph ARTSCAN[" "]
            ARTSCAN_LABEL["Artifact Scanner"]
            AS1["1. Query MLflow<br/>Connect to tracking URI"]
            AS2["2. Filter Models<br/>By project, experiment,<br/>model name (wildcards)"]
            AS3["3. Extract Metadata<br/>Metrics, params,<br/>artifacts, versions"]
            AS1 --> AS2 --> AS3
        end

        subgraph SCAN_OUT[" "]
            SCAN_OUT_LABEL["Scan Outputs"]
            CCTX["CodeContext<br/>─────────────<br/>• Model classes<br/>• Feature names<br/>• Target variable<br/>• Data transformations<br/>• Hyperparameters<br/>• Data sources"]
            ACTX["ArtifactContext<br/>─────────────<br/>• Registered models<br/>• Model versions<br/>• Performance metrics<br/>• Training params<br/>• Artifact paths"]
        end
    end

    %% ==================== PHASE 2: PLANNING ====================
    subgraph PHASE2[" "]
        direction TB
        PHASE2_LABEL["PHASE 2: PLAN - Sequential with Progress"]

        subgraph PLAN_PROCESS[" "]
            PLAN_PROCESS_LABEL["Planning Process"]
            P1["For each Section in Spec"]
            P2{"per_model<br/>flag?"}
            P3["Create subsection<br/>for each model"]
            P4["Build GenerationContext<br/>code + artifacts + hints"]
            P5["LLM Plans Content<br/>Determines what blocks<br/>each section needs"]
        end

        subgraph PLAN_OUT[" "]
            PLAN_OUT_LABEL["Plan Output"]
            SP["SectionPlan[]<br/>─────────────<br/>List of ContentBlocks:<br/>• Type (narrative/table/chart/list)<br/>• Purpose & description<br/>• Data requirements<br/>• Priority (required/optional)"]
        end

        P1 --> P2
        P2 -->|Yes| P3 --> P4
        P2 -->|No| P4
        P4 --> P5 --> SP
    end

    %% ==================== PHASE 3: GENERATION ====================
    subgraph PHASE3[" "]
        direction TB
        PHASE3_LABEL["PHASE 3: GENERATE - Parallel with Semaphore"]

        subgraph GEN_WORKER[" "]
            GEN_WORKER_LABEL["Worker Pool - 4 concurrent"]
            W1["Worker 1"]
            W2["Worker 2"]
            W3["Worker 3"]
            W4["Worker 4"]
        end

        subgraph GEN_TYPES[" "]
            direction LR
            GEN_TYPES_LABEL["Content Generation by Type"]

            subgraph NARR[" "]
                NARR_LABEL["NARRATIVE"]
                N1["Prompt: Write prose<br/>about model purpose"]
                N2["Output: Paragraphs<br/>of technical text"]
            end

            subgraph TABL[" "]
                TABL_LABEL["TABLE"]
                T1["Prompt: Structure<br/>metrics/features data"]
                T2["Output: JSON with<br/>columns & rows"]
            end

            subgraph CHRT[" "]
                CHRT_LABEL["CHART"]
                C1["Prompt: Generate<br/>matplotlib code"]
                C2["Output: PNG bytes<br/>for visualization"]
            end

            subgraph LIST[" "]
                LIST_LABEL["LIST"]
                L1["Prompt: Create<br/>bullet/numbered items"]
                L2["Output: Array of<br/>list entries"]
            end
        end

        subgraph GEN_OUT[" "]
            GEN_OUT_LABEL["Generation Output"]
            SR["SectionResult[]<br/>─────────────<br/>• Section plan reference<br/>• GeneratedContent list<br/>• Any errors encountered"]
        end
    end

    %% ==================== PHASE 4: BUILD ====================
    subgraph PHASE4[" "]
        direction TB
        PHASE4_LABEL["PHASE 4: BUILD - Sequential"]

        subgraph DOCBUILD[" "]
            DOCBUILD_LABEL["Document Builder"]
            DB1["Create DOCX<br/>(python-docx)"]
            DB2["Add title page<br/>title, authors, date"]
            DB3["Add TOC<br/>placeholder"]
            DB4["Render sections<br/>headings, content, images"]
        end

        subgraph NBBUILD[" "]
            NBBUILD_LABEL["Notebook Builder - Optional"]
            NB1["Create .ipynb<br/>(nbformat)"]
            NB2["Markdown cells<br/>for documentation"]
            NB3["Code cells<br/>for reproducibility"]
            NB4["Embed images<br/>as base64"]
        end

        subgraph CACHE[" "]
            CACHE_LABEL["Cache Manager"]
            CM["Save .autodoc_cache.json<br/>for quick rebuilds"]
        end

        DB1 --> DB2 --> DB3 --> DB4
        NB1 --> NB2 --> NB3 --> NB4
    end

    %% ==================== OUTPUT LAYER ====================
    subgraph OUTPUTS[" "]
        direction TB
        OUTPUTS_LABEL["OUTPUTS"]

        DOCX["model_docs.docx<br/>─────────────<br/>• Professional Word document<br/>• Title page & TOC<br/>• Structured sections<br/>• Embedded charts/tables"]

        IPYNB["model_docs_notebook.ipynb<br/>─────────────<br/>• Editable Jupyter notebook<br/>• Markdown documentation<br/>• Executable code cells<br/>• Embedded visualizations"]

        CACHEFILE[".autodoc_cache.json<br/>─────────────<br/>• Serialized results<br/>• Base64-encoded charts<br/>• Enables --notebook-from-cache"]
    end

    %% ==================== CONNECTIONS ====================

    %% Inputs to Entry
    YAML --> CLI
    YAML --> WEB
    ENV --> CLI
    ENV --> WEB

    %% Entry to Phase 1
    CLI --> PHASE1
    WEB --> PHASE1

    %% Inputs to Scanners
    PY --> CS1
    ML --> AS1

    %% Scanner outputs
    CS4 --> CCTX
    AS3 --> ACTX

    %% Phase 1 to Phase 2
    CCTX --> P4
    ACTX --> P4

    %% Phase 2 to Phase 3
    SP --> GEN_WORKER

    %% Worker connections
    W1 --> NARR
    W2 --> TABL
    W3 --> CHRT
    W4 --> LIST

    %% Generation to output
    N2 --> SR
    T2 --> SR
    C2 --> SR
    L2 --> SR

    %% Phase 3 to Phase 4
    SR --> DB1
    SR --> NB1
    SR --> CM

    %% Phase 4 to Outputs
    DB4 --> DOCX
    NB4 --> IPYNB
    CM --> CACHEFILE

    %% ==================== STYLING ====================

